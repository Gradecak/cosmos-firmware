#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &default_layout;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <6>;
        map = <
        // Row 1 (numbers row, 6 keys per side)
        RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
        // Row 2
        RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
        // Row 3
        RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
        // Row 4
        RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
        // Row 5 (2 keys per side, cols 3-4)
        RC(4,2) RC(4,3)                                                         RC(4,8) RC(4,9)
        // Row 6 (thumb cluster, 3 keys per side, inner columns)
                                RC(5,3) RC(5,4) RC(5,5) RC(5,6) RC(5,7) RC(5,8)
        >;
    };

    // Approximate visual layout for ZMK Studio's key map editor. Positions use a
    // standard columnar-stagger curve rather than measured PCB coordinates, since
    // Studio requires a physical layout with a `keys` property (and no chosen
    // matrix-transform) to function - the coordinates only affect the on-screen
    // rendering, not scanning or key behavior. Order matches default_transform's map.
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Cosmos";
        transform = <&default_transform>;
        kscan = <&kscan0>;
        keys
            //                     w   h    x    y   rot  rx  ry
            = <&key_physical_attrs 100 100    0   10   0   0   0>  // RC(0,0)
            , <&key_physical_attrs 100 100  100    0   0   0   0>  // RC(0,1)
            , <&key_physical_attrs 100 100  200  (-10)   0   0   0>  // RC(0,2)
            , <&key_physical_attrs 100 100  300  (-15)   0   0   0>  // RC(0,3)
            , <&key_physical_attrs 100 100  400   (-5)   0   0   0>  // RC(0,4)
            , <&key_physical_attrs 100 100  500   10   0   0   0>  // RC(0,5)
            , <&key_physical_attrs 100 100  600   10   0   0   0>  // RC(0,6)
            , <&key_physical_attrs 100 100  700   (-5)   0   0   0>  // RC(0,7)
            , <&key_physical_attrs 100 100  800  (-15)   0   0   0>  // RC(0,8)
            , <&key_physical_attrs 100 100  900  (-10)   0   0   0>  // RC(0,9)
            , <&key_physical_attrs 100 100 1000    0   0   0   0>  // RC(0,10)
            , <&key_physical_attrs 100 100 1100   10   0   0   0>  // RC(0,11)
            , <&key_physical_attrs 100 100    0  110   0   0   0>  // RC(1,0)
            , <&key_physical_attrs 100 100  100  100   0   0   0>  // RC(1,1)
            , <&key_physical_attrs 100 100  200   90   0   0   0>  // RC(1,2)
            , <&key_physical_attrs 100 100  300   85   0   0   0>  // RC(1,3)
            , <&key_physical_attrs 100 100  400   95   0   0   0>  // RC(1,4)
            , <&key_physical_attrs 100 100  500  110   0   0   0>  // RC(1,5)
            , <&key_physical_attrs 100 100  600  110   0   0   0>  // RC(1,6)
            , <&key_physical_attrs 100 100  700   95   0   0   0>  // RC(1,7)
            , <&key_physical_attrs 100 100  800   85   0   0   0>  // RC(1,8)
            , <&key_physical_attrs 100 100  900   90   0   0   0>  // RC(1,9)
            , <&key_physical_attrs 100 100 1000  100   0   0   0>  // RC(1,10)
            , <&key_physical_attrs 100 100 1100  110   0   0   0>  // RC(1,11)
            , <&key_physical_attrs 100 100    0  210   0   0   0>  // RC(2,0)
            , <&key_physical_attrs 100 100  100  200   0   0   0>  // RC(2,1)
            , <&key_physical_attrs 100 100  200  190   0   0   0>  // RC(2,2)
            , <&key_physical_attrs 100 100  300  185   0   0   0>  // RC(2,3)
            , <&key_physical_attrs 100 100  400  195   0   0   0>  // RC(2,4)
            , <&key_physical_attrs 100 100  500  210   0   0   0>  // RC(2,5)
            , <&key_physical_attrs 100 100  600  210   0   0   0>  // RC(2,6)
            , <&key_physical_attrs 100 100  700  195   0   0   0>  // RC(2,7)
            , <&key_physical_attrs 100 100  800  185   0   0   0>  // RC(2,8)
            , <&key_physical_attrs 100 100  900  190   0   0   0>  // RC(2,9)
            , <&key_physical_attrs 100 100 1000  200   0   0   0>  // RC(2,10)
            , <&key_physical_attrs 100 100 1100  210   0   0   0>  // RC(2,11)
            , <&key_physical_attrs 100 100    0  310   0   0   0>  // RC(3,0)
            , <&key_physical_attrs 100 100  100  300   0   0   0>  // RC(3,1)
            , <&key_physical_attrs 100 100  200  290   0   0   0>  // RC(3,2)
            , <&key_physical_attrs 100 100  300  285   0   0   0>  // RC(3,3)
            , <&key_physical_attrs 100 100  400  295   0   0   0>  // RC(3,4)
            , <&key_physical_attrs 100 100  500  310   0   0   0>  // RC(3,5)
            , <&key_physical_attrs 100 100  600  310   0   0   0>  // RC(3,6)
            , <&key_physical_attrs 100 100  700  295   0   0   0>  // RC(3,7)
            , <&key_physical_attrs 100 100  800  285   0   0   0>  // RC(3,8)
            , <&key_physical_attrs 100 100  900  290   0   0   0>  // RC(3,9)
            , <&key_physical_attrs 100 100 1000  300   0   0   0>  // RC(3,10)
            , <&key_physical_attrs 100 100 1100  310   0   0   0>  // RC(3,11)
            , <&key_physical_attrs 100 100  200  390   0   0   0>  // RC(4,2)
            , <&key_physical_attrs 100 100  300  385   0   0   0>  // RC(4,3)
            , <&key_physical_attrs 100 100  800  385   0   0   0>  // RC(4,8)
            , <&key_physical_attrs 100 100  900  390   0   0   0>  // RC(4,9)
            , <&key_physical_attrs 100 100  300  420   0   0   0>  // RC(5,3)
            , <&key_physical_attrs 100 100  400  440   0   0   0>  // RC(5,4)
            , <&key_physical_attrs 100 100  500  460   0   0   0>  // RC(5,5)
            , <&key_physical_attrs 100 100  600  460   0   0   0>  // RC(5,6)
            , <&key_physical_attrs 100 100  700  440   0   0   0>  // RC(5,7)
            , <&key_physical_attrs 100 100  800  420   0   0   0>  // RC(5,8)
            ;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "row2col";
    };
};